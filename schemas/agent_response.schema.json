{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutoresearchAgentResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "next_sleep_seconds",
    "sleep_reason",
    "jobs_submitted",
    "artifacts_updated",
    "plan_updates",
    "current_phase",
    "phase_plan",
    "next_action",
    "acknowledged_input_ids",
    "lark_update_markdown",
    "final_summary_markdown",
    "model_switch_recommended",
    "stop_reason"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "working",
        "waiting_job",
        "blocked",
        "done",
        "failed"
      ]
    },
    "summary": {
      "type": "string"
    },
    "next_sleep_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "sleep_reason": {
      "type": "string"
    },
    "jobs_submitted": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "job_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "script": {
            "type": "string"
          },
          "log_out": {
            "type": "string"
          },
          "log_err": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "job_id",
          "status",
          "script",
          "log_out",
          "log_err",
          "notes"
        ]
      }
    },
    "artifacts_updated": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plan_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "status"
        ],
        "properties": {
          "step": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed"
            ]
          }
        }
      }
    },
    "current_phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "goal",
        "related_plan_step",
        "related_job_ids",
        "status"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "goal": {
          "type": "string"
        },
        "related_plan_step": {
          "type": "string"
        },
        "related_job_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string"
        }
      }
    },
    "phase_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "reason",
        "primary_target",
        "resume_targets",
        "search_patterns",
        "read_ladder",
        "success_condition",
        "fallback_if_missing"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "primary_target": {
          "type": "string"
        },
        "resume_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "search_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "read_ladder": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_condition": {
          "type": "string"
        },
        "fallback_if_missing": {
          "type": "string"
        }
      }
    },
    "acknowledged_input_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lark_update_markdown": {
      "type": "string"
    },
    "final_summary_markdown": {
      "type": "string"
    },
    "model_switch_recommended": {
      "type": "string"
    },
    "stop_reason": {
      "type": "string"
    }
  }
}
